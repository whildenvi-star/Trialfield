# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (must match ecosystem.config.js)
PORT=3002

# ── CORS ───────────────────────────────────────────
# Portal origin for CORS allowlist (your production portal URL)
# Example: https://portal.yourfarm.com
PORTAL_ORIGIN=https://portal.farm.example.com

# ── Node Environment ──────────────────────────────
NODE_ENV=production
