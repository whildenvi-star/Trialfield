# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (must match ecosystem.config.js)
PORT=3003

# ── CORS ───────────────────────────────────────────
# Portal origin for CORS allowlist (your production portal URL)
# Example: https://portal.yourfarm.com
PORTAL_ORIGIN=https://portal.farm.example.com

# ── Embed Token ───────────────────────────────────
# Shared secret — must match EMBED_TOKEN in glomalin-portal .env
# Generate with: openssl rand -base64 32
EMBED_TOKEN=

# ── Grain Tickets Connection ──────────────────────
# URL for grain-tickets app (settlement price sync)
GRAIN_TICKETS_URL=http://localhost:3007
# Token for server-to-server calls (defaults to EMBED_TOKEN)
# GRAIN_TICKETS_TOKEN=

# ── Node Environment ──────────────────────────────
NODE_ENV=production
