# ═══════════════════════════════════════════════════════════════════
# Caddyfile — Farm Operations Platform Reverse Proxy
# ═══════════════════════════════════════════════════════════════════
#
# Domain is configured via the DOMAIN environment variable.
# Default: whughesfarms.com (placeholder — set to your actual domain)
#
# Usage:
#   DOMAIN=yourdomain.com caddy run
#   DOMAIN=yourdomain.com caddy start   (background)
#
# Prerequisites:
#   - DNS: *.yourdomain.com A record pointing to VPS IP
#   - All 8 apps running via PM2 (see ecosystem.config.js)
#
# Port Map (matches ecosystem.config.js):
#   3000  glomalin-portal   portal.{DOMAIN}    Next.js 14
#   3001  farm-budget        budget.{DOMAIN}    Express
#   3002  fsa-acres          fsa.{DOMAIN}       Express
#   3003  meristem-malt      malt.{DOMAIN}      Express
#   3004  organic-cert       cert.{DOMAIN}      Next.js 16
#   3005  farm-registry      registry.{DOMAIN}  Express
#   3006  seed-inventory     seed.{DOMAIN}      Express
#   3007  grain-tickets      tickets.{DOMAIN}   Express
#
# Caddy handles auto-HTTPS via Let's Encrypt — no explicit TLS
# config needed. HTTP requests are redirected to HTTPS automatically.
# ═══════════════════════════════════════════════════════════════════

# ── Root domain ────────────────────────────────────────────────────
# Root domain (whughesfarms.com) stays on Squarespace — no Caddy block.
# Only subdomains are handled here.

# ── Portal (Next.js 14) ─────────────────────────────────────────
# Embedded apps are proxied under /embed/* so iframes share the
# portal's origin (same localStorage, no cross-origin isolation).
portal.{$DOMAIN:whughesfarms.com} {
	encode gzip

	# ── Same-origin embed proxies ──────────────────────────────
	handle_path /embed/farm-budget/* {
		reverse_proxy localhost:3001
	}
	handle_path /embed/grain-tickets/* {
		reverse_proxy localhost:3007
	}
	handle_path /embed/seed-inventory/* {
		reverse_proxy localhost:3006
	}
	handle_path /embed/farm-registry/* {
		reverse_proxy localhost:3005
	}
	# organic-cert is Next.js — can't use handle_path (asset paths
	# like /_next/* would resolve to the portal). Use subdomain embed.
	# Kept here as a comment for documentation.
	# handle_path /embed/organic-cert/* { ... }
	handle_path /embed/meristem-malt/* {
		reverse_proxy localhost:3003
	}
	handle_path /embed/fsa-acres/* {
		reverse_proxy localhost:3002
	}

	# ── Portal app (catch-all) ─────────────────────────────────
	reverse_proxy localhost:3000 {
		header_up X-Forwarded-Proto {scheme}
	}
}

# ── Farm Budget (Express) ───────────────────────────────────────
budget.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3001
}

# ── FSA Acres (Express) ─────────────────────────────────────────
fsa.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3002
}

# ── Meristem Malt (Express) ─────────────────────────────────────
malt.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3003
}

# ── Organic Cert (Next.js 16) ───────────────────────────────────
cert.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3004 {
		header_up X-Forwarded-Proto {scheme}
	}
}

# ── Farm Registry (Express) ─────────────────────────────────────
registry.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3005
}

# ── Seed Inventory (Express) ────────────────────────────────────
seed.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3006
}

# ── Grain Tickets (Express) ─────────────────────────────────────
tickets.{$DOMAIN:whughesfarms.com} {
	encode gzip
	reverse_proxy localhost:3007
}
