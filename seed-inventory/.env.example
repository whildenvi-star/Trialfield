# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (must match ecosystem.config.js)
PORT=3006

# ── CORS ───────────────────────────────────────────
# Portal origin for CORS allowlist (your production portal URL)
# Example: https://portal.yourfarm.com
PORTAL_ORIGIN=https://portal.farm.example.com

# ── Embed Token ───────────────────────────────────
# Shared secret — must match EMBED_TOKEN in glomalin-portal .env
# Generate with: openssl rand -base64 32
EMBED_TOKEN=

# ── Farm Budget Connection ───────────────────────
# Token for server-to-server calls to farm-budget (defaults to EMBED_TOKEN)
# FARM_BUDGET_TOKEN=
# FARM_BUDGET_URL=http://localhost:3001

# ── Node Environment ──────────────────────────────
NODE_ENV=production
