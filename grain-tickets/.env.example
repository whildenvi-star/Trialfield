# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (must match ecosystem.config.js)
PORT=3007

# ── CORS ───────────────────────────────────────────
# Portal origin for CORS allowlist (your production portal URL)
# Example: https://portal.yourfarm.com
PORTAL_ORIGIN=https://portal.farm.example.com

# ── Yield Push Targets (Phase 52) ─────────────────
# URLs for yield push recipients — defaults work for local dev
# Override in production if apps are on different hosts/ports
BUDGET_API_URL=http://localhost:3001

# ── Embed Token ───────────────────────────────────
# Shared secret — must match EMBED_TOKEN in glomalin-portal .env
# Generate with: openssl rand -base64 32
EMBED_TOKEN=

# ── Node Environment ──────────────────────────────
NODE_ENV=production

# ── Database ───────────────────────────────────────
# PostgreSQL connection string for grain-tickets
# Local dev: typically no password needed with trust/peer auth
DATABASE_URL="postgresql://user:password@localhost:5432/grain_tickets?schema=public"

# ── Anthropic API ──────────────────────────────────
# Anthropic API key — required for barcode scan AI and chat agent
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Chat Agent ─────────────────────────────────────
# Chat agent kill-switch — set to "true" to enable the Glomalin chat agent
CHAT_AGENT_ENABLED=true

# Daily message cap for chat agent (optional, defaults to 50)
CHAT_DAILY_CAP=50
