# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (must match ecosystem.config.js)
PORT=3001

# ── CORS ───────────────────────────────────────────
# Portal origin for CORS allowlist (your production portal URL)
# Example: https://portal.yourfarm.com
PORTAL_ORIGIN=https://portal.farm.example.com

# ── Node Environment ──────────────────────────────
NODE_ENV=production

# ── Anthropic API (optional) ──────────────────────
# Anthropic Claude API key (for Glomalin terminal chat)
ANTHROPIC_API_KEY=

# ── Case IH FieldOps API ─────────────────────────
# Register at https://develop.cnh.com to get these credentials
# Set FIELDOPS_USE_MOCK=true if not available
FIELDOPS_CLIENT_ID=
FIELDOPS_CLIENT_SECRET=
FIELDOPS_SUBSCRIPTION_KEY=

# OAuth2 endpoints (defaults work for most users)
FIELDOPS_TOKEN_URL=https://identity.cnhind.com/oauth/token
FIELDOPS_API_BASE=https://ag.api.cnhind.com

# Sync configuration
FIELDOPS_SYNC_ENABLED=false
FIELDOPS_SYNC_INTERVAL_MINUTES=60
FIELDOPS_USE_MOCK=true
