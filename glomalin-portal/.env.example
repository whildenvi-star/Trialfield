# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (Next.js default)
PORT=3000

# ── Node Environment ──────────────────────────────
NODE_ENV=production

# ── Supabase ──────────────────────────────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Embedded Module URLs (LOCAL DEV ONLY) ────────
# In production, Caddy proxies /embed/<app>/* to Express ports
# (same-origin — iframes share localStorage for theme/text-scale).
# These env vars override the default /embed/ paths for local dev
# where you don't have the Caddy proxy running.
NEXT_PUBLIC_EMBED_URL_GRAIN_TICKETS=http://localhost:3007
NEXT_PUBLIC_EMBED_URL_FARM_BUDGET=http://localhost:3001
NEXT_PUBLIC_EMBED_URL_MERISTEM_MALT=http://localhost:3003
NEXT_PUBLIC_EMBED_URL_ORG_CERT=http://localhost:3004
NEXT_PUBLIC_EMBED_URL_FARM_REGISTRY=http://localhost:3005
NEXT_PUBLIC_EMBED_URL_SEED_INVENTORY=http://localhost:3006

# ── Server-side service URLs ─────────────────────
# Used by Next.js route handlers to call Express services. NOT baked into
# client JS (no NEXT_PUBLIC_ prefix). Defaults to localhost — only override
# if services run on a different host than the portal.
# REGISTRY_SERVICE_URL=http://localhost:3005
# BUDGET_SERVICE_URL=http://localhost:3001
# CERT_SERVICE_URL=http://localhost:3004
# GT_SERVICE_URL=http://localhost:3007
# SEED_SERVICE_URL=http://localhost:3006

# ── Embed Token ──────────────────────────────────
# Shared secret appended as ?token= to iframe URLs.
# Each Express app must have the same EMBED_TOKEN set.
# Generate with: openssl rand -base64 32
EMBED_TOKEN=

# ── Reverse Proxy ────────────────────────────────
# In production behind Caddy, set NEXT_PUBLIC_SITE_URL to your portal subdomain:
# NEXT_PUBLIC_SITE_URL=https://portal.yourdomain.com
#
# Each Express app's PORTAL_ORIGIN should also use the portal subdomain:
# PORTAL_ORIGIN=https://portal.yourdomain.com
#
# See Caddyfile at repo root for the full subdomain-to-port mapping.

# ── Climate FieldView ────────────────────────────
# Register at dev.fieldview.com — receive client_id, client_secret, X-Api-Key on approval.
FIELDVIEW_CLIENT_ID=
FIELDVIEW_CLIENT_SECRET=
FIELDVIEW_API_KEY=
FIELDVIEW_REDIRECT_URI=https://portal.whughesfarms.com/api/fsa/fieldview/callback

# ── Precip App ───────────────────────────────────
# Set base URL once API docs are reviewed.
PRECIP_APP_API_KEY=
PRECIP_APP_BASE_URL=

# ── Crop Year ─────────────────────────────────────
# Auto-derived: Jan–Oct = current year, Nov–Dec = next year.
# Override only when you need to force a specific year:
# NEXT_PUBLIC_CROP_YEAR=2026
