# Copy this file to .env and fill in your values
# See ecosystem.config.js for port assignments

# ── App Configuration ──────────────────────────────
# Port this app listens on (Next.js default)
PORT=3000

# ── Node Environment ──────────────────────────────
NODE_ENV=production

# ── Supabase ──────────────────────────────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Embedded Module URLs ──────────────────────────
# Set these to the host:port where each Express app is running
# In production, use internal URLs (e.g., http://localhost:PORT)
NEXT_PUBLIC_EMBED_URL_GRAIN_TICKETS=http://localhost:3007
NEXT_PUBLIC_EMBED_URL_FARM_BUDGET=http://localhost:3001
NEXT_PUBLIC_EMBED_URL_MERISTEM_MALT=http://localhost:3003
NEXT_PUBLIC_EMBED_URL_ORG_CERT=http://localhost:3004
NEXT_PUBLIC_EMBED_URL_FARM_REGISTRY=http://localhost:3005
NEXT_PUBLIC_EMBED_URL_SEED_INVENTORY=http://localhost:3006
